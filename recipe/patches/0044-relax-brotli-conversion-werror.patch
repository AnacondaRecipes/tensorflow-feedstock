From 1234567890abcdef1234567890abcdef12345678 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Fri, 13 Mar 2026 17:20:00 -0700
Subject: [PATCH] Relax Brotli conversion warning policy for GCC builds

On linux-aarch64, GCC emits a -Wconversion warning in Brotli's
c/common/platform.h (BrotliRotateRight16), and upstream Brotli's Bazel config
promotes warnings to errors with -Werror.

Patch the downloaded org_brotli repository to keep strict warnings while making
conversion warnings non-fatal via -Wno-error=conversion.

---
 third_party/org_brotli/BUILD                         | 2 ++
 third_party/org_brotli/brotli_werror_conversion.patch | 20 ++++++++++++++++++++
 third_party/org_brotli/workspace.bzl                | 1 +
 3 files changed, 23 insertions(+)
 create mode 100644 third_party/org_brotli/brotli_werror_conversion.patch

diff --git a/third_party/org_brotli/BUILD b/third_party/org_brotli/BUILD
index 94210a033a8..8e6b6930bc1 100644
--- a/third_party/org_brotli/BUILD
+++ b/third_party/org_brotli/BUILD
@@ -1,3 +1,5 @@
 # This empty BUILD file is required to make Bazel treat this directory as a package.
 
 # copybara:uncomment package(default_applicable_licenses = ["//tensorflow:license"])
+
+exports_files(["brotli_werror_conversion.patch"])
diff --git a/third_party/org_brotli/brotli_werror_conversion.patch b/third_party/org_brotli/brotli_werror_conversion.patch
new file mode 100644
index 00000000000..9f2378f4ad1
--- /dev/null
+++ b/third_party/org_brotli/brotli_werror_conversion.patch
@@ -0,0 +1,11 @@
+diff --git a/BUILD.bazel b/BUILD.bazel
+index 35eb302..ed5e79b 100644
+--- a/BUILD.bazel
+++ b/BUILD.bazel
+@@ -36,6 +36,7 @@ STRICT_C_OPTIONS = select({
+         "--pedantic-errors",
+         "-Wall",
+         "-Wconversion",
++        "-Wno-error=conversion",
+         "-Werror",
+         "-Wextra",
+         "-Wlong-long",
diff --git a/third_party/org_brotli/workspace.bzl b/third_party/org_brotli/workspace.bzl
index ca8b1ca7bf4..d07ea581f4d 100644
--- a/third_party/org_brotli/workspace.bzl
+++ b/third_party/org_brotli/workspace.bzl
@@ -8,4 +8,5 @@ def repo():
         name = "org_brotli",
         strip_prefix = "brotli-1.2.0",
         sha256 = "816c96e8e8f193b40151dad7e8ff37b1221d019dbcb9c35cd3fadbfe6477dfec",
+        patch_file = ["//third_party/org_brotli:brotli_werror_conversion.patch"],
         urls = tf_mirror_urls("https://github.com/google/brotli/archive/refs/tags/v1.2.0.tar.gz"),
