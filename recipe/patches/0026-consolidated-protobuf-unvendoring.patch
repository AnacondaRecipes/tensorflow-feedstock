@@ -0,0 +1,11 @@
+"""Stub java_lite_proto_library.bzl for TF_SYSTEM_LIBS=com_google_protobuf.
+
+Provides a no-op java_lite_proto_library macro since Java protos are not
+needed for the TensorFlow conda build.
+"""
+
+def java_lite_proto_library(name, **kwargs):
+    native.filegroup(
+        name = name,
+        visibility = kwargs.get("visibility", ["//visibility:public"]),
+    )
