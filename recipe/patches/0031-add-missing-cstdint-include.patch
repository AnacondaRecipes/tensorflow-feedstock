From a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b1 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Mon, 3 Mar 2026 10:01:00 -0700
Subject: [PATCH] Add missing #include <cstdint> to builtin_fp16.h

The header uses uint16_t but relies on a transitive include that is not
guaranteed by all toolchains. GCC on aarch64 in particular fails without
the explicit include.

---
 third_party/xla/xla/backends/cpu/codegen/builtin_fp16.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/third_party/xla/xla/backends/cpu/codegen/builtin_fp16.h b/third_party/xla/xla/backends/cpu/codegen/builtin_fp16.h
index cbe75ec2e18..b24cee4bcaa 100644
--- a/third_party/xla/xla/backends/cpu/codegen/builtin_fp16.h
+++ b/third_party/xla/xla/backends/cpu/codegen/builtin_fp16.h
@@ -16,6 +16,8 @@ limitations under the License.
 #ifndef XLA_BACKENDS_CPU_CODEGEN_BUILTIN_FP16_H_
 #define XLA_BACKENDS_CPU_CODEGEN_BUILTIN_FP16_H_
 
+#include <cstdint>
+
 // _Float16 always gets us the correct ABI type, so use that if available.
 // AArch64 GCC defines __FLT16_MANT_DIG__ even when _Float16 is not available.
 #if defined(__FLT16_MANT_DIG__) && \
