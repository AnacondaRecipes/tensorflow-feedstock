From fedcba9876543210fedcba9876543210fedcba98 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Fri, 13 Mar 2026 19:40:00 -0700
Subject: [PATCH] Make plugin registry static_assert dependent on template
 parameter

`static_assert(false, ...)` in a templated `if constexpr` fallback branch can
trigger eagerly on some compilers. Use a dependent false helper so the assert
only fires for unsupported instantiations.

---
 third_party/xla/xla/stream_executor/plugin_registry.cc | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/third_party/xla/xla/stream_executor/plugin_registry.cc b/third_party/xla/xla/stream_executor/plugin_registry.cc
index 36f2ea97a18..bf6fd3f5f62 100644
--- a/third_party/xla/xla/stream_executor/plugin_registry.cc
+++ b/third_party/xla/xla/stream_executor/plugin_registry.cc
@@ -32,6 +32,8 @@ namespace stream_executor {
   return instance;
 }
 
+template <typename T>
+inline constexpr bool kUnsupportedFactoryType = false;
 template <typename FactoryT>
 PluginKind GetPluginKind() {
   if constexpr (std::is_same_v<FactoryT, PluginRegistry::BlasFactory>) {
@@ -41,7 +43,7 @@ PluginKind GetPluginKind() {
   } else if constexpr (std::is_same_v<FactoryT, PluginRegistry::FftFactory>) {
     return PluginKind::kFft;
   } else {
-    static_assert(false, "Unsupported factory type");
+    static_assert(kUnsupportedFactoryType<FactoryT>, "Unsupported factory type");
   }
 }
 template <typename FactoryT>
@@ -53,7 +55,7 @@ absl::string_view GetPluginName() {
   } else if constexpr (std::is_same_v<FactoryT, PluginRegistry::FftFactory>) {
     return "FFT";
   } else {
-    static_assert(false, "Unsupported factory type");
+    static_assert(kUnsupportedFactoryType<FactoryT>, "Unsupported factory type");
   }
 }
 
