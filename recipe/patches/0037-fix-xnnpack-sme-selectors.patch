From a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b3 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Mon, 3 Mar 2026 10:03:00 -0700
Subject: [PATCH] Fix XNNPACK build_defs.bzl typo and add missing newline

Two fixes to the XNNPACK layering_check_fix patch that TF carries:

1. The patch file was missing a trailing newline, causing git apply
   issues.

2. In build_defs.bzl the explicit_false branch of define_build_option's
   select() incorrectly pointed to explicit_true, making it impossible
   to disable a build option. This is an upstream XNNPACK bug.

---
 .../xla/third_party/xnnpack/layering_check_fix.patch | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/third_party/xla/third_party/xnnpack/layering_check_fix.patch b/third_party/xla/third_party/xnnpack/layering_check_fix.patch
--- a/third_party/xla/third_party/xnnpack/layering_check_fix.patch
+++ b/third_party/xla/third_party/xnnpack/layering_check_fix.patch
@@ -10,3 +10,17 @@
          "x86_fma3.inc",
          "x86_sse2.inc",
          "x86_sse41.inc",
\ No newline at end of file
+
+diff --git a/ynnpack/build_defs.bzl b/ynnpack/build_defs.bzl
+--- a/ynnpack/build_defs.bzl
++++ b/ynnpack/build_defs.bzl
+@@ -39,7 +39,7 @@ def define_build_option(name, default_all = [], default_any = []):
+     native.alias(
+         name = name,
+         actual = select({
+             explicit_true: ":" + explicit_true,
+-            explicit_false: ":" + explicit_true,
++            explicit_false: ":" + explicit_false,
+             "//conditions:default": ":" + default,
+         }),
+     )
