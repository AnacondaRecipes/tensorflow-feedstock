From 76543210fedcba9876543210fedcba9876543210 Mon Sep 17 00:00:00 2001
From: Eric Lundby <Eric.Lundby@gmail.com>
Date: Fri, 13 Mar 2026 20:45:00 -0700
Subject: [PATCH] Disambiguate NoDestructor initialization in ynn_support

On linux-aarch64 with newer Abseil, brace-init of NoDestructor payloads can be
ambiguous. Construct the flat_hash_set explicitly to avoid overload ambiguity.

---
 third_party/xla/xla/backends/cpu/ynn_support.cc | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/third_party/xla/xla/backends/cpu/ynn_support.cc b/third_party/xla/xla/backends/cpu/ynn_support.cc
index 2f9f0e9d2c4..2d79a781c6f 100644
--- a/third_party/xla/xla/backends/cpu/ynn_support.cc
+++ b/third_party/xla/xla/backends/cpu/ynn_support.cc
@@ -170,6 +170,6 @@ absl::StatusOr<bool> IsDotSupportedByYnn(
   static const absl::NoDestructor<absl::flat_hash_set<
       std::tuple<PrimitiveType, PrimitiveType, PrimitiveType>>>
-      kAllowedTypes({
+      kAllowedTypes(absl::flat_hash_set<std::tuple<PrimitiveType, PrimitiveType, PrimitiveType>>{
           {F32, F32, F32},
           // TODO(b/449998002): We don't have fast fp16 kernels yet.
           // {F16, F16, F32},
@@ -319,7 +319,7 @@ bool IsConvolutionOpSupportedByYnn(const HloInstruction* instr) {
   // TODO(b/466474339): Enable other data types.
   static const absl::NoDestructor<absl::flat_hash_set<
       std::tuple<PrimitiveType, PrimitiveType, PrimitiveType>>>
-      kAllowedTypes({/*{F32, F32, F32}, {BF16, BF16, F32},*/ {S8, S8, S32}});
+      kAllowedTypes(absl::flat_hash_set<std::tuple<PrimitiveType, PrimitiveType, PrimitiveType>>{/*{F32, F32, F32}, {BF16, BF16, F32},*/ {S8, S8, S32}});
 
   const Shape& lhs_shape = conv->operand(0)->shape();
   const Shape& rhs_shape = conv->operand(1)->shape();
